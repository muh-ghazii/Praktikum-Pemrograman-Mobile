<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.TipCalculatorXML" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="MaroonTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxStrokeColor">@color/maroon</item>
        <item name="hintTextColor">@color/maroon</item>
        <item name="android:textColorHint">@color/maroon</item>
        <item name="colorControlActivated">@color/maroon</item>
    </style>

    <style name="MaroonTextInputLayout.ExposedDropdownMenu" parent="Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu">
        <item name="boxStrokeColor">@color/maroon</item>
        <item name="hintTextColor">@color/maroon</item>
        <item name="android:textColorHint">@color/maroon</item>
        <item name="colorControlActivated">@color/maroon</item>
    </style>

    <style name="MaroonSwitchTheme" parent="ThemeOverlay.MaterialComponents">
        <item name="colorPrimary">#800000</item>
        <item name="colorControlActivated">#800000</item>
        <item name="colorSurface">#800000</item>
    </style>

    <style name="Theme.TipCalculatorXML" parent="Base.Theme.TipCalculatorXML" />
</resources>